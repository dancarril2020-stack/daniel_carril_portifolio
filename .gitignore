# ═══════════════════════════════════════════════════
# .gitignore — Daniel Carril Portfolio
# ═══════════════════════════════════════════════════

# ── Windows ────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── VS Code ────────────────────────────────────────
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# ── JetBrains IDEs ─────────────────────────────────
.idea/
*.iml

# ── Node (if you ever add a build step) ────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# ── Build output ───────────────────────────────────
dist/
build/
.cache/

# ── Environment variables ──────────────────────────
.env
.env.local
.env.*.local

# ── Misc ───────────────────────────────────────────
*.log
*.tmp
*.bak
